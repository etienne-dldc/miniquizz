{
  "name": "miniquizz",
  "exports": "./main.tsx",
  "version": "0.2.0",
  "tasks": {
    "bump": "deno run -A jsr:@mys/bump@1",
    "deps:outdated": "deno outdated",
    "deps:update": "deno outdated --update --latest --interactive",
    "check": "deno fmt --check . && deno lint . && deno check .",
    "start": "deno run --allow-net --allow-env --allow-read --no-prompt main.tsx",
    "dev": "ADMIN_PASSWORD=admin DATA_FOLDER_PATH=./data deno run --allow-net --allow-env --allow-read --no-prompt --watch main.tsx",
    "test:run": "deno test --allow-all"
  },
  "imports": {
    "@dldc/hono-ui": "jsr:@dldc/hono-ui@^2.0.4",
    "@dldc/pubsub": "jsr:@dldc/pubsub@^7.1.0",
    "@hono/hono": "jsr:@hono/hono@^4.12.19",
    "@hono/standard-validator": "jsr:@hono/standard-validator@^0.2.2",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.1",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@valibot/valibot": "jsr:@valibot/valibot@^1.4.0",
    "hono": "jsr:@hono/hono@^4.12.19",
    "lucide-static": "npm:lucide-static@^1.16.0",
    "shiki": "npm:shiki@^4.0.2"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  "fmt": {
    "lineWidth": 140
  },
  "exclude": [
    "public"
  ]
}
