{
  "name": "miniquizz",
  "exports": "./main.tsx",
  "version": "0.13.5",
  "tasks": {
    "bump": "deno run -A jsr:@mys/bump@1",
    "deps:outdated": "deno outdated",
    "deps:update": "deno outdated --update --latest --interactive",
    "check": "deno fmt --check . && deno lint . && deno check .",
    "start": "deno run --config deno.json --allow-net --allow-env --allow-read --allow-write=/app/storage --no-prompt main.tsx",
    "dev": "deno run --env-file=.env --config deno.json --allow-net --allow-env --allow-read --allow-write=./storage --no-prompt --watch main.tsx",
    "test:run": "deno test --allow-all"
  },
  "imports": {
    "@dldc/hono-ui": "jsr:@dldc/hono-ui@^2.3.1",
    "@dldc/pubsub": "jsr:@dldc/pubsub@^7.1.0",
    "@dldc/tsx-doc": "jsr:@dldc/tsx-doc@^0.2.0",
    "@dldc/zenjson": "jsr:@dldc/zenjson@^3.0.1",
    "@hono/hono": "jsr:@hono/hono@^4.12.22",
    "@hono/standard-validator": "jsr:@hono/standard-validator@^0.2.2",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.1",
    "@std/async": "jsr:@std/async@^1.3.0",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@valibot/valibot": "jsr:@valibot/valibot@^1.4.0",
    "immer": "npm:immer@^11.1.8",
    "lucide-static": "npm:lucide-static@^1.16.0",
    "shiki": "npm:shiki@^4.1.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@hono/hono/jsx"
  },
  "fmt": {
    "lineWidth": 140
  },
  "exclude": [
    "public/libs",
    "data"
  ]
}
