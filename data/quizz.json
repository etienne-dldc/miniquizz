    {
      "question": [
        {
          "type": "text",
          "text": "Which JavaScript values are falsy?"
        },
        {
          "type": "code-line",
          "code": "if (value) { /* truthy */ }"
        }
      ],
      "options": [
        {
          "content": [
            {
              "type": "code-line",
              "code": "0"
            }
          ],
          "isCorrect": true
        },
        {
          "content": [
            {
              "type": "code-line",
              "code": "\"\""
            }
          ],
          "isCorrect": true
        },
        {
          "content": [
            {
              "type": "code-line",
              "code": "[]"
            }
          ],
          "isCorrect": false
        },
        {
          "content": [
            {
              "type": "code-line",
              "code": "\"0\""
            }
          ],
          "isCorrect": false
        }
      ],
      "explanation": [
        {
          "type": "text",
          "text": "In JavaScript, the falsy values are: false, 0, -0, 0n, \"\", null, undefined, and NaN. Arrays and strings are truthy even if empty, and \"0\" is a non-empty string so it's truthy."
        }
      ]
    },
